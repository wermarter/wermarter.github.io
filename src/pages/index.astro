---
import BaseLayout from "../layouts/BaseLayout.astro";
import BotanicalSketch from "../components/BotanicalSketch.astro";
import { coreSkills, experience, profile } from "../data/personal";
import { formatMonthYear, formatPeriod, getDuration, toYearMonth } from "../utils/calendar";
const recentRoles = experience.slice(0, 3);
---

<BaseLayout>
  <section class="hero home-hero">
    <div class="hero__copy">
      <p class="eyebrow">Backend engineer · system gardener</p>
      <h1>Building systems that can <em>grow.</em></h1>
      <p class="lede">{profile.tagline}</p>
      <div class="hero__actions">
        <a class="button" href="/projects/">See what I’ve built</a>
        <a class="button button--quiet" href={`mailto:${profile.email}`}>Write to me</a>
      </div>
    </div>
    <BotanicalSketch class="hero__plant" />
  </section>

  <section class="content-section home-section" aria-labelledby="about-title">
    <div class="section-heading home-section__heading">
      <div><p class="eyebrow">A short introduction</p><h2 id="about-title">Hello, I’m Chiến.</h2></div>
      <div><p>{profile.summary}</p><p class="hand-note">Clear systems. Calm operations. Useful software.</p></div>
    </div>
    <div class="skills-strip">
      {coreSkills.map((skill) => <a class="skill" href={`/projects/?skill=${encodeURIComponent(skill.name)}`}><strong>{skill.name}</strong><span>Explore {skill.projectCount} related projects →</span></a>)}
    </div>
  </section>

  <section class="content-section home-section" aria-labelledby="experience-title">
    <div class="section-heading home-section__heading">
      <div><p class="eyebrow">Where I’ve worked</p><h2 id="experience-title">Experience</h2></div>
      <p>From solo delivery on an on-premise laboratory platform to distributed systems operated across international teams.</p>
    </div>
    <div class="experience-preview">
      {recentRoles.map((role) => (
        <a class="experience-row" href={`/experience/#${role.id}`} aria-label={`View ${role.title} at ${role.company}`}>
          <div class="experience-row__period" aria-label={`${formatPeriod(role)}, ${getDuration(role)}`}>
            <span><time datetime={toYearMonth(role.startMonth, role.startYear)}>{formatMonthYear(role.startMonth, role.startYear)}</time> <span aria-hidden="true">→</span> {role.endMonth && role.endYear ? <time datetime={toYearMonth(role.endMonth, role.endYear)}>{formatMonthYear(role.endMonth, role.endYear)}</time> : "Present"}</span>
            <small>{getDuration(role)}</small>
          </div>
          <div><h3>{role.title}</h3><p>{role.company}</p></div>
          <span class="experience-row__arrow" aria-hidden="true">↗</span>
        </a>
      ))}
    </div>
    <p><a class="button button--quiet" href="/experience/">Full experience</a></p>
  </section>

  <section class="contact-note home-contact">
    <div><p class="eyebrow">Let’s compare notes</p><h2>Have a difficult system problem?</h2><p>I enjoy backend architecture, distributed workflows, platform reliability, and code that leaves the next person with fewer surprises.</p></div>
    <a class="hand-note" href={`mailto:${profile.email}`}>say hello ↗</a>
  </section>
</BaseLayout>
