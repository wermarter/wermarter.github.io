---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import ContentRowList from "../../components/ContentRowList.astro";
import { allProjects, experience, type Project } from "../../data/personal";
import { formatMonthYear, formatPeriod, getDuration, toYearMonth } from "../../utils/calendar";

export async function getStaticPaths() {
  const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (left, right) => right.data.publishedAt.valueOf() - left.data.publishedAt.valueOf(),
  );

  return allProjects.map((project) => ({
    params: { id: project.id },
    props: {
      project,
      company: experience.find((role) => role.projects.some(({ id }) => id === project.id))?.company,
      relatedPosts: posts.filter((post) =>
        post.data.tags.some((tag) => tag.type === "project" && tag.value === project.id),
      ),
    },
  }));
}

interface Props {
  project: Project;
  company?: string;
  relatedPosts: CollectionEntry<"blog">[];
}

const { project, company, relatedPosts } = Astro.props;
const isOngoing = project.endMonth === null || project.endYear === null;
---

<BaseLayout title={project.name} description={`${project.description} Explore the work, outcomes, technology, and related field notes.`}>
  <article class="project-detail">
    <header class="project-detail__hero">
      <span class="project-detail__watermark" aria-hidden="true">{project.id}</span>
      <div class="project-detail__intro">
        <a class="back-link" href="/projects/">← All projects</a>
        <p class="eyebrow">{company ?? "Independent work"}</p>
        <h1>{project.name}</h1>
        <p class="project-detail__lede">{project.description}</p>
        {project.url && <a class="button project-detail__external" href={project.url} target="_blank" rel="noopener noreferrer">Open project <span aria-hidden="true">↗</span></a>}
      </div>

      <dl class="project-facts" aria-label="Project facts" data-reveal>
        <div class="project-facts__period">
          <dt>Field period</dt>
          <dd aria-label={`${formatPeriod(project)}, ${getDuration(project)}`}>
            <time datetime={toYearMonth(project.startMonth, project.startYear)}>{formatMonthYear(project.startMonth, project.startYear)}</time>
            <span aria-hidden="true">→</span>
            {project.endMonth && project.endYear
              ? <time datetime={toYearMonth(project.endMonth, project.endYear)}>{formatMonthYear(project.endMonth, project.endYear)}</time>
              : <strong>Present</strong>}
          </dd>
          <p>{getDuration(project)} · {isOngoing ? "Ongoing" : "Completed"}</p>
        </div>
        <div>
          <dt>{project.roles.length === 1 ? "Role" : "Roles"}</dt>
          <dd>{project.roles.join(" · ")}</dd>
        </div>
        {project.team && <div><dt>Team</dt><dd>{project.team}</dd></div>}
      </dl>
    </header>

    <section class="project-detail__work" aria-labelledby="outcomes-title">
      <div class="project-outcomes">
        <div class="project-detail__section-heading" data-reveal>
          <p class="eyebrow">What changed</p>
          <h2 id="outcomes-title">The work, in outcomes.</h2>
        </div>
        <ul class="outcome-list">
          {project.achievements.map((achievement) => (
            <li data-reveal><span aria-hidden="true"></span><p>{achievement}</p></li>
          ))}
        </ul>
      </div>

      <aside class="project-toolkit" aria-labelledby="toolkit-title" data-reveal>
        <p class="eyebrow">Working set</p>
        <h2 id="toolkit-title">Tools & technology</h2>
        <div class="tag-list">
          {project.technologies.map((technology) => (
            <a href={`/projects/?skill=${encodeURIComponent(technology)}`}>{technology}</a>
          ))}
        </div>
        <p>Each tool links back to the wider work index, where you can trace it across projects and field notes.</p>
      </aside>
    </section>

    <section class="project-detail__notes" aria-labelledby="related-notes-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Written context</p>
          <h2 id="related-notes-title">Related field notes</h2>
        </div>
        <p>{relatedPosts.length > 0
          ? "Notes written from this project: the decisions, trade-offs, and lessons behind the work."
          : "This project does not have a published field note yet. The project page will collect them here as they grow."}</p>
      </div>
      {relatedPosts.length > 0
        ? <ContentRowList>{relatedPosts.map((post) => <BlogCard post={post} />)}</ContentRowList>
        : <div class="empty-note" data-reveal><p class="eyebrow">Nothing published yet</p><h2>The field book is still open.</h2><p>For now, the outcomes and technology above are the complete project record.</p></div>}
    </section>
  </article>
</BaseLayout>

<style>
  .project-detail {
    --project-gutter: var(--content-gutter);
  }

  .project-detail__hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(270px, .7fr);
    align-items: end;
    gap: clamp(2.5rem, 6vw, 5rem);
    overflow: hidden;
    padding: var(--space-section-compact) var(--project-gutter);
    border-bottom: 1px solid var(--line);
    background: linear-gradient(125deg, transparent 42%, var(--bark-wash));
    isolation: isolate;
  }

  .project-detail__watermark {
    position: absolute;
    z-index: -1;
    right: -.04em;
    bottom: -.24em;
    color: color-mix(in srgb, var(--bark) 6%, transparent);
    font: 520 clamp(8rem, 22vw, 20rem)/.8 var(--display);
    letter-spacing: -.08em;
    pointer-events: none;
  }

  .project-detail__intro {
    max-width: 800px;
  }

  .project-detail .back-link {
    margin-bottom: clamp(2rem, 3vw, 2.75rem);
  }

  .project-detail__intro h1 {
    max-width: 11ch;
    margin: 0;
    overflow-wrap: anywhere;
    font: 520 clamp(3.5rem, 7.5vw, 7rem)/.92 var(--display);
    letter-spacing: -.055em;
    text-wrap: balance;
  }

  .project-detail__lede {
    max-width: 62ch;
    margin: 1.25rem 0 0;
    color: var(--ink-soft);
    font-size: clamp(1.1rem, 1.7vw, 1.3rem);
    line-height: 1.55;
    text-wrap: pretty;
  }

  .project-detail__external {
    gap: .3rem;
    margin-top: 1.5rem;
  }

  .project-facts {
    position: relative;
    margin: 0;
    padding: clamp(1.5rem, 3vw, 2.2rem);
    border: 1px solid var(--line);
    border-radius: 12px 5px 12px 5px;
    background: color-mix(in srgb, var(--paper-raised) 90%, transparent);
    box-shadow: 0 6px 0 var(--shadow);
    backdrop-filter: blur(12px);
  }

  .project-facts > div {
    padding-block: 1.15rem;
    border-bottom: 1px solid var(--line);
  }

  .project-facts > div:first-child {
    padding-top: 0;
  }

  .project-facts > div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .project-facts dt {
    margin-bottom: .35rem;
    color: var(--bark);
    font-size: .67rem;
    font-weight: 800;
    letter-spacing: .13em;
    text-transform: uppercase;
  }

  .project-facts dd {
    margin: 0;
    font-weight: 650;
    line-height: 1.45;
  }

  .project-facts__period dd {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: .35rem;
    font-variant-numeric: tabular-nums;
  }

  .project-facts__period dd span {
    color: var(--bark-soft);
  }

  .project-facts__period dd strong {
    color: var(--leaf);
  }

  .project-facts__period p {
    margin: .35rem 0 0;
    color: var(--ink-soft);
    font-size: .78rem;
  }

  .project-detail__work {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(260px, .65fr);
    gap: clamp(3rem, 6vw, 6rem);
    padding: var(--space-section) var(--project-gutter);
    border-bottom: 1px solid var(--line);
  }

  .project-detail__section-heading h2,
  .project-toolkit h2 {
    margin: 0;
    font: 540 clamp(2.4rem, 4.2vw, 4rem)/.98 var(--display);
    letter-spacing: -.04em;
    text-wrap: balance;
  }

  .outcome-list {
    position: relative;
    display: grid;
    gap: 0;
    margin: clamp(2.25rem, 4vw, 3.5rem) 0 0;
    padding: 0;
    list-style: none;
  }

  .outcome-list::before {
    content: "";
    position: absolute;
    top: .9rem;
    bottom: .9rem;
    left: .45rem;
    width: 1px;
    background: linear-gradient(var(--bark), var(--line) 12%, var(--line) 88%, var(--leaf));
    transform: rotate(.15deg);
    transform-origin: top;
  }

  .outcome-list li {
    position: relative;
    display: grid;
    grid-template-columns: 1rem minmax(0, 1fr);
    gap: 1.3rem;
    padding: 0 0 2rem;
  }

  .outcome-list li:last-child {
    padding-bottom: 0;
  }

  .outcome-list li > span {
    position: relative;
    z-index: 1;
    width: .9rem;
    aspect-ratio: 1;
    margin-top: .48rem;
    border: 2px solid var(--bark);
    border-radius: 56% 44% 58% 42%;
    background: var(--paper);
    transform: rotate(24deg);
    transition: background-color .25s ease, transform .35s var(--ease-out);
  }

  .outcome-list li:hover > span {
    background: var(--leaf-bright);
    transform: rotate(54deg) scale(1.12);
  }

  .outcome-list p {
    max-width: 70ch;
    margin: 0;
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .project-toolkit {
    align-self: start;
    padding: clamp(1.5rem, 3vw, 2.2rem);
    border: solid var(--line);
    border-width: 1px 0;
  }

  .project-toolkit h2 {
    font-size: clamp(2rem, 3.5vw, 3.25rem);
  }

  .project-toolkit .tag-list {
    margin-top: 1.7rem;
  }

  .project-toolkit .tag-list a {
    font-size: .82rem;
  }

  .project-toolkit > p:last-child {
    margin: 1.7rem 0 0;
    color: var(--ink-soft);
    font-size: .9rem;
  }

  .project-detail__notes {
    padding: var(--space-section) var(--project-gutter);
    border-bottom: 1px solid var(--line);
  }

  @media (max-width: 900px) {
    .project-detail__hero,
    .project-detail__work {
      grid-template-columns: 1fr;
    }

    .project-detail__hero {
      align-items: start;
    }

    .project-facts,
    .project-toolkit {
      max-width: 680px;
    }
  }

  @media (max-width: 620px) {
    .project-detail__intro h1 {
      font-size: clamp(3.6rem, 16vw, 5.4rem);
    }

    .project-detail__hero {
      gap: 2.5rem;
      padding-top: 3rem;
    }

    .project-detail .back-link {
      margin-bottom: 2rem;
    }

    .project-detail__work {
      gap: 3rem;
    }

    .outcome-list li {
      gap: .9rem;
    }
  }
</style>
