---
import BaseLayout from "./BaseLayout.astro";
import ReferenceTag from "../components/ReferenceTag.astro";
import "../styles/prose.css";
import type { BlogReference } from "../data/blog";
interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags: BlogReference[];
}
const { title, description, publishedAt, updatedAt, tags } = Astro.props;
const date = new Intl.DateTimeFormat("en", { dateStyle: "long" });
---

<BaseLayout title={title} description={description}>
  <article class="blog-post">
    <header class="blog-post__header">
      <a class="back-link" href="/blog/">← All notes</a>
      <p class="eyebrow">Field note · <time datetime={publishedAt.toISOString()}>{date.format(publishedAt)}</time></p>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <div class="tag-list tag-list--references">{tags.map((tag) => <ReferenceTag reference={tag} />)}</div>
      {updatedAt && <p class="updated">Last tended {date.format(updatedAt)}</p>}
    </header>
    <div class="prose"><slot /></div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--space-section) clamp(1.25rem, 5vw, 4rem);
  }

  .blog-post__header {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--line);
  }

  h1 {
    margin: 0;
    font-family: var(--display);
    font-size: clamp(3rem, 6.5vw, 5.5rem);
    font-weight: 520;
    letter-spacing: -.045em;
    line-height: .96;
  }

  .lede {
    color: var(--ink-soft);
    font-size: 1.18rem;
  }

  .updated {
    margin-top: 1rem;
    color: var(--ink-soft);
    font: 1.2rem var(--hand);
  }
</style>
