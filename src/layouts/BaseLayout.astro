---
import "@fontsource-variable/newsreader";
import "@fontsource-variable/atkinson-hyperlegible-next";
import "@fontsource-variable/caveat";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { profile } from "../data/personal";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = profile.name,
  description = profile.summary,
} = Astro.props;
const pageTitle = title === profile.name ? `${profile.name} — ${profile.title}` : `${title} — ${profile.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#edf0e1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <title>{pageTitle}</title>
    <script is:inline>
      document.documentElement.classList.add("js");
      const savedTheme = localStorage.getItem("theme");
      document.documentElement.dataset.theme = savedTheme || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="paper-shell">
      <Header />
      <main id="main"><slot /></main>
      <Footer />
    </div>
    <script>
      const revealItems = document.querySelectorAll<HTMLElement>(
        ".section-heading, .content-row, .skill, .role, .empty-note, .contact-note > *, .prose > *, [data-reveal]",
      );
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!reduceMotion && "IntersectionObserver" in window) {
        revealItems.forEach((item, index) => {
          item.dataset.reveal = "";
          item.style.setProperty("--reveal-order", String(index % 4));
        });
        document.documentElement.classList.add("motion-ready");

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          { rootMargin: "0px 0px -8%", threshold: 0.08 },
        );

        revealItems.forEach((item) => observer.observe(item));
      }
    </script>
  </body>
</html>

<style>
  .paper-shell {
    position: relative;
    width: min(100%, var(--site-width));
    min-height: 100vh;
    margin-inline: auto;
    overflow: clip;
    background:
      repeating-linear-gradient(2deg, transparent 0 13px, rgb(55 71 58 / 2%) 14px 15px),
      var(--paper);
    box-shadow: 0 0 60px var(--shadow);
    transition: background-color .35s ease, box-shadow .35s ease;
  }

  .skip-link {
    position: fixed;
    z-index: 20;
    top: -5rem;
    left: 1rem;
    padding: .6rem 1rem;
    background: var(--ink);
    color: var(--paper);
  }

  .skip-link:focus {
    top: 1rem;
  }
</style>
