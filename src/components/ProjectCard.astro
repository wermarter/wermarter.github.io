---
import type { Project } from "../data/personal";
interface Props { project: Project; }
const { project } = Astro.props;
---

<article class="project-card" id={project.id}>
  <div class="project-card__topline"><span>{project.period}</span><span>{project.role}</span></div>
  <h3>{project.url ? <a href={project.url}>{project.name}</a> : project.name}</h3>
  <p>{project.description}</p>
  <ul>
    {project.achievements.slice(0, 3).map((achievement) => <li>{achievement}</li>)}
  </ul>
  <div class="tag-list" aria-label="Technologies">
    {project.technologies.map((technology) => <span>{technology}</span>)}
  </div>
</article>

