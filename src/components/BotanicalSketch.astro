---
interface Props { class?: string; label?: string; }
const { class: className = "", label = "" } = Astro.props;
---

<svg class:list={["botanical-sketch", className]} viewBox="0 0 320 220" role={label ? "img" : "presentation"} aria-label={label || undefined} aria-hidden={label ? undefined : "true"}>
  <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
    <path class="branch stem" d="M156 208c3-41-6-78 7-113 9-25 29-46 50-63" />
    <path class="branch echo" d="M160 208c1-40-4-75 9-110 9-24 27-44 47-61" />
    <path class="leaf leaf--1" d="M165 103c-29-1-52-16-62-40 30-1 52 15 62 40Z" />
    <path class="leaf leaf--2" d="M182 75c3-25 19-45 43-54 1 26-16 46-43 54Z" />
    <path class="leaf leaf--3" d="M157 143c-27 3-49-8-62-30 27-4 49 7 62 30Z" />
    <path class="leaf leaf--4" d="M169 122c23-6 43 1 57 20-23 7-43 0-57-20Z" />
    <path class="veins" d="M125 87c11-2 24 5 35 15M204 49c-8 6-15 15-21 26M114 123c14 2 29 8 42 19M209 136c-12-3-25-1-39 6" />
    <path class="pot" d="M117 189h80l-9 26h-61l-10-26Z" />
  </g>
</svg>

<style>
  path {
    vector-effect: non-scaling-stroke;
    stroke-width: 2.1;
  }

  .branch,
  .veins {
    stroke: var(--bark);
  }

  .echo {
    opacity: .45;
    stroke-width: 1;
  }

  .veins {
    opacity: .62;
    stroke-width: 1.2;
  }

  .leaf {
    stroke: var(--leaf);
  }

  .pot {
    fill: var(--paper);
    stroke: var(--bark);
  }

  @media (prefers-reduced-motion: no-preference) {
    .branch {
      stroke-dasharray: 420;
      stroke-dashoffset: 420;
      animation: draw-branch 1.8s .25s var(--ease-out) forwards;
    }

    .leaf,
    .veins,
    .pot {
      opacity: 0;
      animation: leaf-in .65s var(--ease-out) forwards;
    }

    .leaf--1 { animation-delay: .55s; }
    .leaf--2 { animation-delay: .68s; }
    .leaf--3 { animation-delay: .81s; }
    .leaf--4 { animation-delay: .94s; }
    .veins { animation-delay: 1.07s; }
    .pot { animation-delay: .35s; }
  }

  @keyframes draw-branch {
    to { stroke-dashoffset: 0; }
  }

  @keyframes leaf-in {
    from {
      opacity: 0;
      transform: translateY(5px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
