---
import ThemeToggle from "./ThemeToggle";
import { profile } from "../data/personal";
const path = Astro.url.pathname;
const links = [
  { href: "/", label: "Home" },
  { href: "/experience/", label: "Experience" },
  { href: "/projects/", label: "Projects" },
  { href: "/blog/", label: "Notes" },
];
---

<header class="site-header">
  <a class="wordmark" href="/" aria-label={`${profile.name}, home`}>
    <span aria-hidden="true">wm</span>
    <span>{profile.name}</span>
  </a>
  <nav aria-label="Main navigation">
    {links.map((link) => <a href={link.href} aria-current={path === link.href || (link.href !== "/" && path.startsWith(link.href)) ? "page" : undefined}>{link.label}</a>)}
  </nav>
  <ThemeToggle client:load />
</header>

<style>
  .site-header {
    position: sticky;
    z-index: 10;
    top: 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2rem);
    min-height: 68px;
    padding: .6rem clamp(1.25rem, 5vw, 5rem);
    border-bottom: 1px solid var(--line);
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: blur(16px) saturate(.8);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: .8rem;
    width: fit-content;
    font-family: var(--display);
    font-size: 1.05rem;
    font-weight: 650;
    text-decoration: none;
  }

  .wordmark > span:first-child {
    display: grid;
    place-items: center;
    width: 2rem;
    aspect-ratio: 1;
    border: 1.5px solid var(--bark);
    border-radius: 48% 52% 44% 56%;
    color: var(--bark);
    font: 700 1.15rem var(--hand);
    transform: rotate(-4deg);
    transition: transform .4s var(--ease-out), background-color .25s ease;
  }

  .wordmark:hover > span:first-child {
    background: var(--bark-wash);
    transform: rotate(2deg) scale(1.04);
  }

  nav {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.2rem);
    font-size: .92rem;
  }

  nav a {
    position: relative;
    padding-block: .45rem;
    text-decoration: none;
  }

  nav a::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: .15rem;
    left: 0;
    height: 1.5px;
    border-radius: 50%;
    background: var(--bark);
    transform: scaleX(0) rotate(-1deg);
    transform-origin: right;
    transition: transform .35s var(--ease-out);
  }

  nav a:hover::after,
  nav a[aria-current="page"]::after {
    transform: scaleX(1) rotate(-1deg);
    transform-origin: left;
  }

  @media (max-width: 900px) {
    .site-header {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: clamp(.75rem, 2.5vw, 1.5rem);
    }

    nav {
      min-width: 0;
      justify-content: center;
      gap: clamp(.75rem, 2.5vw, 1.5rem);
    }
  }

  @media (max-width: 620px) {
    .site-header {
      gap: .5rem;
      min-height: 60px;
      padding: .5rem .625rem;
    }

    .wordmark > span:last-child {
      display: none;
    }

    nav {
      justify-content: space-between;
      gap: .25rem;
      font-size: .75rem;
    }

    nav a {
      padding: .35rem .1rem;
    }
  }
</style>
